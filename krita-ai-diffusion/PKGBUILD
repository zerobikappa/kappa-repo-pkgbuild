pkgname=krita-ai-diffusion
pkgver=1.50.0
pkgrel=1
pkgdesc="A plugin to use generative AI in image painting and editing workflows from within Krita"
arch=('any')
url="https://github.com/Acly/krita-ai-diffusion"
license=('GPL-3.0-or-later')
depends=(
    'krita'
    'python-pyqt5'
    'qt5-imageformats'
)
install=krita-ai-diffusion.install
source=("${url}/releases/download/v${pkgver}/krita_ai_diffusion-${pkgver}.zip")
sha256sums=('e412d681c6ed8197b51fca84d3ff8b788912830bbe43620891f4a42668832c8c')

prepare() {
    patch --strip=1 --input=../krita-ai-diffusion.patch
}
#
#build() {
#}
#
#check() {
#}

package() {
    cd "${srcdir}"
    mkdir -p "${pkgdir}"/usr/share/krita/actions/
    mv ai_diffusion/ai_diffusion.action "${pkgdir}"/usr/share/krita/actions/
    mkdir -p "${pkgdir}"/usr/share/krita/pykrita/
    mv ai_diffusion ai_diffusion.desktop "${pkgdir}"/usr/share/krita/pykrita/
}
