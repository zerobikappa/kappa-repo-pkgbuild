#}

package() {
    cd "${srcdir}"
    mkdir -p "${pkgdir}"/usr/share/krita/actions/
    mv ai_diffusion/ai_diffusion.action "${pkgdir}"/usr/share/krita/actions/
    mkdir -p "${pkgdir}"/usr/share/krita/pykrita/
    mv ai_diffusion ai_diffusion.desktop "${pkgdir}"/usr/share/krita/pykrita/
}
