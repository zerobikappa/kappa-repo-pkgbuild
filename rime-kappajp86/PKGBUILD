# Maintainer: Mikata Riko <sanbikappa at qq dot com>

pkgname=rime-kappajp86
pkgver=r25.6a89e0c
pkgrel=1
epoch=
pkgdesc="rime-kappajp86 - Japan IME with Wubi86 schema."
arch=('any')
url="https://github.com/zerobikappa/rime-kappajp86"
license=('unknow')
depends=('opencc')
makedepends=('git' 'librime' 'rime-prelude')
source=("git+https://github.com/zerobikappa/rime-kappajp86")
md5sums=('SKIP')

pkgver() {
    cd "$srcdir/$pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

prepare() {
    cd "$srcdir/$pkgname"
    # Link essentials
    for _f in $(pacman -Qql rime-prelude | grep -v "/$"); do ln -sf $_f; done
}

build() {
    cd "$srcdir/$pkgname"
    for _s in $(ls *.schema.yaml); do rime_deployer --compile $_s; done

    cd "$srcdir/$pkgname/openccAdditionalFiles"
    opencc_dict --input hiragana_to_katakana_characters.txt --from text --to ocd2 --output hiragana_to_katakana_characters.ocd2

}

package() {
    cd "$srcdir/$pkgname"
    find . -type l -delete
    rm build/*.txt
    install -Dm644 *.yaml -t "$pkgdir"/usr/share/rime-data/
    install -Dm644 build/* -t "$pkgdir"/usr/share/rime-data/build/
    install -Dm644 openccAdditionalFiles/hiragana*.{json,ocd2} -t "$pkgdir"/usr/share/opencc/
}
